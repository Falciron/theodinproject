<%= title(@lesson.display_title) %>

<div class="bg-white dark:bg-gray-900">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 xl:flex xl:gap-x-10 xl:max-w-none xl:px-4"
       data-controller="lesson-toc diagramming"
       data-lesson-toc-item-classes-value="no-underline hover:text-gray-800 text-sm dark:hover:text-gray-300">

      <%= turbo_frame_tag 'lesson-sidebar-frame',
            src: lesson_sidebar_path(@lesson),
            target: '_top',
            class: 'block xl:w-72 xl:shrink-0 border-gray-200 dark:border-gray-800 xl:border-r' do %>
        <%= render 'lessons/sidebar_skeleton' %>
      <% end %>

      <main class="pt-10 sm:pt-14 xl:flex-1 xl:min-w-0">
        <div class="mx-auto xl:max-w-[65ch]">
          <%= render 'lessons/header', lesson: @lesson %>

          <article>
          <%= render ContentContainerComponent.new(classes: 'xl:mx-0 pb-6', data_attributes: { lesson_toc_target: 'lessonContent' }) do |component| %>
            <%= @lesson.body.html_safe %>

            <% component.with_footer do %>
              <div class="flex flex-col gap-2">
                <%= link_to github_edit_url(@lesson), target: :_blank, rel: 'noreferrer', class: 'inline-flex items-center underline hover:no-underline text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 pr-5 text-sm' do %>
                  <%= inline_svg_tag 'icons/github.svg', class: 'h-4 w-4 mr-1 inline', aria: true, title: 'Improve on GitHub', desc: 'Github logo icon' %>
                  <span>Improve on GitHub</span>
                <% end %>

                <%= link_to github_report_url(@lesson, 'broken_link'), target: :_blank, rel: 'noreferrer', class: 'inline-flex items-center underline hover:no-underline text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 pr-5 text-sm' do %>
                  <%= inline_svg_tag 'icons/link.svg', class: 'h-4 w-4 mr-1 inline', aria: true, title: 'Report broken link', desc: 'Broken link icon' %>
                  <span>Report broken link</span>
                <% end %>

                <%= link_to github_report_url(@lesson, 'suggestion'), target: :_blank, rel: 'noreferrer', class: 'inline-flex items-center underline hover:no-underline text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 pr-5 text-sm' do %>
                  <%= inline_svg_tag 'icons/flag.svg', class: 'h-4 w-4 mr-1 inline', aria: true, title: 'Report other issue', desc: 'Report icon' %>
                  <span>Report other issue</span>
                <% end %>
              </div>

              <div>
                <%= link_to github_commits_url(@lesson), target: :_blank, rel: 'noreferrer', class: 'underline hover:no-underline text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 text-sm text-right' do %>
                  See lesson changelog
                <% end %>
              </div>
            <% end %>
          <% end %>

          <% if user_signed_in? && @lesson.accepts_submission? %>
            <div class="py-10 border-t border-gray-100 dark:border-white/5">
              <div class="max-w-2xl mx-auto xl:max-w-full border border-gray dark:border-white/5 rounded-lg p-4 dark:bg-gray-800">
                <%= render 'lessons/project_solution', lesson: @lesson, project_submission: @project_submission %>
              </div>
            </div>
          <% end %>

          <div class="pt-10 border-t border-gray-100 dark:border-white/5">
            <%= render 'lesson_buttons', lesson: @lesson, course: @lesson.course, user: @user %>
          </div>
        </article>
        </div>
      </main>

      <aside class="hidden xl:block xl:w-72 xl:shrink-0">
        <div class="sticky top-12 pt-10 sm:pt-14 pb-20">
          <h4 class="text-md pb-4 text-gray-700 dark:text-gray-300">Lesson contents</h4>
          <ul class="flex flex-col text-gray-500 dark:text-gray-400" data-lesson-toc-target="toc"></ul>
        </div>
      </aside>
    </div>
  </div>
